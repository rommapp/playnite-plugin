<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" x:Class="RomM.Settings.SettingsView"
    xmlns:local="clr-namespace:RomM.Settings"
    xmlns:sys="clr-namespace:System;assembly=mscorlib" mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="800" Padding="2,0,2,4">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <local:ImageCacheConverter x:Key="imageCacheConverter" />
    </UserControl.Resources>

    <DockPanel Margin="20">
        <ScrollViewer DockPanel.Dock="Top">
            <StackPanel x:Name="EmulatorSettingsPanel">
                <Label Content="Authentication" FontWeight="Bold" />
                <Separator Margin="0,5,0,10" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="255"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <!-- RomM User data -->
                    <Image Name="RomMProfileIcon" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Source="{Binding ProfilePath, Mode=OneWay, Converter={StaticResource imageCacheConverter}}" Width="120" HorizontalAlignment="Left" Margin="5,5,0,5" />
                    <Label Name="RomMUser" Content="{Binding RomMUser, Mode=OneWay}" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" FontSize="22" VerticalAlignment="Bottom" Margin="-30,0,0,0"/>
                    <Label Name="RomMProfileType" Content="{Binding RomMProfileType, Mode=OneWay}" Grid.Row="1" Grid.Column="1" Margin="-30,0,0,0" Foreground="DimGray" FontSize="12" VerticalAlignment="Top"/>
                    <Button Name="TestServer" Click="Click_TestConnection" Grid.Row="1" Grid.Column="3" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Label Content="Test Connection" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Label Content="Failed!" Grid.Row="1" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Bottom" FontSize="12" Foreground="Red" Visibility="{Binding ConnectionFailed, Converter={StaticResource BoolToVisConverter}}"/>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Label Name="RomMServerVersionText" Content="Server Ver." Foreground="DimGray" FontSize="12" VerticalAlignment="Top" HorizontalAlignment="Right"/>
                        <Label Name="RomMServerVersion" Content="{Binding ServerVersion, Mode=OneWay}" Grid.Row="0" Grid.Column="3" Margin="0" Foreground="DimGray" FontSize="12" VerticalAlignment="Top" HorizontalAlignment="Right"/>
                    </StackPanel>
                    

                    <!-- RomM Host Label and TextBox -->
                    <Label Content="RomM Host" Grid.Row="2" Grid.Column="0" Margin="0,0,5,5"/>
                    <TextBox x:Name="RomMHost" Grid.Row="2" Grid.Column="1" Margin="2" Width="250" MaxWidth="250" HorizontalAlignment="Left" Text="{Binding RomMHost, Mode=TwoWay}" />

                    <!-- RomM API Key -->
                    <Label Content="RomM Client Token (&gt;=4.8)" Grid.Row="3" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                    <TextBox x:Name="RomMApiKey" Grid.Row="3" Grid.Column="1" Margin="2" Width="250" MaxWidth="250" HorizontalAlignment="Left" Text="{Binding RomMClientToken, Mode=TwoWay}" />
                    <TextBlock Grid.Row="3" Grid.Column="2" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Hyperlink NavigateUri="{Binding GetAPIUrl}" RequestNavigate="Hyperlink_RequestNavigate">
                            Get Token
                        </Hyperlink>
                    </TextBlock>

                    <CheckBox IsChecked="{Binding UseBasicAuth, Mode=TwoWay}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Use Basic Auth" TextWrapping="Wrap" FontSize="12"/>
                    </CheckBox>

                    <!-- Username Label and TextBox -->
                    <Label Content="Username" Grid.Row="5" Grid.Column="0" Margin="40,0,5,5" Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}"/>
                    <TextBox x:Name="RomMUsername" Grid.Row="5" Grid.Column="1" Margin="2" Width="250" MaxWidth="250" HorizontalAlignment="Left" Text="{Binding RomMUsername, Mode=TwoWay}" Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}"/>

                    <!-- Password Label and TextBox -->
                    <Label Content="Password" Grid.Row="6" Grid.Column="0" Margin="40,5,5,0"  Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}"/>
                    <TextBox x:Name="RomMPassword" Grid.Row="6" Grid.Column="1" Margin="2" Width="250" MaxWidth="250" HorizontalAlignment="Left" Text="{Binding RomMPassword, Mode=TwoWay}" Visibility="{Binding UseBasicAuth, Converter={StaticResource BoolToVisConverter}}"/>
                </Grid>
                <Label Content="Emulator path mappings" FontWeight="Bold" />
                <TextBlock HorizontalAlignment="Right" Margin="0,-16,0,0">
                    <Hyperlink NavigateUri="https://github.com/rommapp/playnite-plugin/blob/main/README.md" RequestNavigate="Hyperlink_RequestNavigate">
                        Help
                    </Hyperlink>
                </TextBlock>
                <Separator Margin="0,5,0,10" />
                <Grid Height="Auto" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" Padding="0,0,0,4" ItemsSource="{Binding Mappings}" AutoGenerateColumns="False" CellEditEnding="DataGrid_CellEditEnding" CurrentCellChanged="DataGrid_CurrentCellChanged" SelectionUnit="Cell" CanUserAddRows="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="❌" Tag="{Binding}" Click="Click_Delete" Foreground="Red" Width="26" Margin="0" Padding="0" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBlock Text=""></TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Emulator" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock x:Name="Emulator" Text="{Binding Path=Emulator.Name, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Name="ComboEmulators" DockPanel.Dock="Left" ItemsSource="{Binding AvailableEmulators}" DisplayMemberPath="Name" SelectedItem="{Binding Emulator, Mode=TwoWay}">
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Profile" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock x:Name="Profile" Text="{Binding Path=EmulatorProfile.Name, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Name="ComboPlatforms" DockPanel.Dock="Left" ItemsSource="{Binding AvailableProfiles}" DisplayMemberPath="Name" SelectedItem="{Binding EmulatorProfile, Mode=TwoWay}">
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Platform" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock x:Name="Platform" Text="{Binding Path=Platform.Name, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox Name="ComboPlatforms" DockPanel.Dock="Left" ItemsSource="{Binding AvailablePlatforms}" DisplayMemberPath="Name" SelectedItem="{Binding Platform, Mode=TwoWay}">
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Destination Path" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock x:Name="Path" Text="{Binding Path=DestinationPath,UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <Button Name="Browse" Click="Click_BrowseDestination"></Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridCheckBoxColumn Header="Auto-extract" Binding="{Binding AutoExtract}" />
                            <DataGridCheckBoxColumn Header="Use M3U File" Binding="{Binding UseM3u}" />
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" />
                            <DataGridTextColumn Header="Mapping ID" IsReadOnly="True" Binding="{Binding MappingId}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                <Label Content="Library scanning" FontWeight="Bold" Margin="0,10,0,0" />
                <Separator Margin="0,5,0,10" />

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Exclude Genres" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5"/>

                    <Grid>
                        <TextBox  Width="250"  VerticalAlignment="Center" HorizontalAlignment="Left" x:Name="SearchTermTextBox" Margin="5" Text="{Binding ExcludeGenres, Mode=TwoWay}"/>
                        <TextBlock IsHitTestVisible="False" Text="Adventure;Platform;RPG;" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="DarkGray">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTermTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
                <CheckBox IsChecked="{Binding ScanGamesInFullScreen, Mode=TwoWay}" Margin="0,0,0,10">
                    <TextBlock Text="Enable game scanning in fullscreen mode" TextWrapping="Wrap"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding MergeRevisions, Mode=TwoWay}" Margin="0,0,0,10">
                    <TextBlock Text="Merge ROM revisions" TextWrapping="Wrap"/>
                </CheckBox>
                <Label Content="Installation" FontWeight="Bold" Margin="0,10,0,0" />
                <Separator Margin="0,5,0,10" />
                <CheckBox IsChecked="{Binding NotifyOnInstallComplete, Mode=TwoWay}" Margin="0,0,0,10">
                    <TextBlock Text="Enable notification upon game install completion" TextWrapping="Wrap"/>
                </CheckBox>
                <Label Content="Status Sync" FontWeight="Bold" Margin="0,10,0,0" />
                <Separator Margin="0,5,0,10" />
                <CheckBox IsChecked="{Binding KeepRomMSynced, Mode=TwoWay}" Margin="0,0,0,10">
                    <TextBlock Text="Keep completion status and favorites in sync with RomM" TextWrapping="Wrap"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding KeepDeletedGames, Mode=TwoWay}" Margin="0,0,0,10">
                    <TextBlock Text="Keep games deleted from RomM server" TextWrapping="Wrap"/>
                </CheckBox>
                <CheckBox IsChecked="{Binding SkipMissingFiles, Mode=TwoWay}" Margin="0,0,0,10">
                    <TextBlock Text="Skip importing ROMs that are missing from RomM servers filesystem" TextWrapping="Wrap"/>
                </CheckBox>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox IsChecked="{Binding Use7z, Mode=TwoWay}" Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Use 7z for archive extraction" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBox x:Name="PathTo7zText" Grid.Row="0" Grid.Column="1" Margin="3,2,0,2" Text="{Binding PathTo7z, Mode=TwoWay}" />
                    <Button Name="Browse7z" Click="Click_Browse7zDestination" Grid.Row="0" Grid.Column="2">
                        <Label Content="Browse" Grid.Row="0" Grid.Column="0" Margin="0,0,5,5"/>
                    </Button>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
